# Copy to .env and replace with your own strong values

# PostgreSQL password (used by docker-compose)
DB_PASSWORD=change_me_to_strong_password

# JWT signing key (generate at least 32 random bytes hex)
SECRET_KEY=change_me_to_long_random_secret_at_least_32_chars

# Database connection (for non-compose local runs)
DATABASE_URL=postgresql://postgres:change_me_to_strong_password@db:5432/kuberone

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
